{
  "name": "Python 3.14 Bot",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Keep Alive Port",
      "onAutoForward": "notify",
      "visibility": "public"
    }
  },
  "customizations": {
    "codesandbox": {
      "tasks": {
        "run": "python main.py"
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt"
}